<Window x:Class="DeviceCertAgent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DeviceCertAgent.App.Converters"
        Title="VerifyTech Agent"
        Width="960" Height="720" MinWidth="840" MinHeight="640"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <conv:PageVisibilityConverter x:Key="PageVis"/>
    <conv:StepStatusIconConverter x:Key="StepIcon"/>
    <conv:StepStatusBrushConverter x:Key="StepBrush"/>
    <conv:BoolVisConverter x:Key="BoolVis"/>
    <conv:FunctionalStepVisibilityConverter x:Key="FuncStepVis"/>
  </Window.Resources>

  <Grid Margin="28">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,24">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Border Width="44" Height="44" CornerRadius="10" Background="{StaticResource AccentBrush}" Margin="0,0,14,0">
          <TextBlock Text="VT" Foreground="White" FontWeight="Bold" FontSize="16"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <StackPanel>
          <TextBlock Text="VerifyTech Agent" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
          <TextBlock Text="{Binding BrandSubtitle}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>
      </StackPanel>
    </StackPanel>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <Grid MaxWidth="780">

        <!-- 1 Welcome -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Welcome}">
          <TextBlock Text="Certify this device" Style="{StaticResource PageTitle}" Margin="0,0,0,10"/>
          <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,28"
                     Text="Run a secure hardware diagnostic and receive a trusted certificate backed by VerifyTech — ideal for resale, trade-in, and refurbishment."/>
          <Border Style="{StaticResource HeroCardBorder}" Margin="0,0,0,24">
            <StackPanel>
              <TextBlock Text="What you get" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"/>
              <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,0" Text="• Hardware identity and condition snapshot"/>
              <TextBlock Style="{StaticResource BodyText}" Text="• Server-signed certificate (not created on this PC)"/>
              <TextBlock Style="{StaticResource BodyText}" Text="• Shareable report link and certificate code"/>
              <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0" Foreground="{StaticResource AccentBrush}"
                         Text="No personal files, photos, or browsing data are collected."/>
              <TextBlock Style="{StaticResource BodyText}" Margin="0,12,0,0" TextWrapping="Wrap"
                         Text="Requires .NET 8 Desktop Runtime (x64). If the app won't start, install from dotnet.microsoft.com/download/dotnet/8.0 or run Launch-VerifyTechAgent.cmd."/>
            </StackPanel>
          </Border>
          <StackPanel Orientation="Horizontal">
            <Button Content="Start certification" Style="{StaticResource AccentButton}" Command="{Binding BeginCertificationCommand}" Margin="0,0,10,0"/>
            <Button Content="Enter pairing code" Style="{StaticResource SecondaryButton}" Command="{Binding OpenManualPairingCommand}"/>
          </StackPanel>
        </StackPanel>

        <!-- Pairing manual -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=PairingManual}">
          <TextBlock Text="Enter pairing code" Style="{StaticResource PageTitle}" Margin="0,0,0,12"/>
          <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,16"
                     Text="Paste the code from certronx.com if the browser did not open this app automatically. Codes expire in 2 minutes."/>
          <TextBox Text="{Binding ManualPairingCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" Padding="10" FontFamily="Consolas"/>
          <StackPanel Orientation="Horizontal">
            <Button Content="Connect" Style="{StaticResource AccentButton}" Command="{Binding SubmitManualPairingCodeCommand}" Margin="0,0,10,0"/>
            <Button Content="Back" Style="{StaticResource SecondaryButton}" Command="{Binding BackToWelcomeCommand}"/>
          </StackPanel>
          <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" Margin="0,12,0,0"
                     Visibility="{Binding HasError, Converter={StaticResource BoolVis}}"/>
        </StackPanel>

        <!-- Pairing connecting -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=PairingConnecting}">
          <TextBlock Text="Connecting to Certronx" Style="{StaticResource PageTitle}" Margin="0,0,0,12"/>
          <TextBlock Style="{StaticResource BodyText}" Text="{Binding StatusMessage}" Margin="0,0,0,8"/>
        </StackPanel>

        <!-- 2 Disclosure -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Disclosure}">
          <TextBlock Text="What we collect" Style="{StaticResource PageTitle}" Margin="0,0,0,12"/>
          <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
            <StackPanel>
              <TextBlock Style="{StaticResource BodyText}" Text="To certify your device we collect hardware specifications and health signals only:"/>
              <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,0" Text="• CPU, memory, storage, battery, and graphics"/>
              <TextBlock Style="{StaticResource BodyText}" Text="• BIOS / motherboard identifiers (hashed on this device)"/>
              <TextBlock Style="{StaticResource BodyText}" Text="• OS version, Secure Boot, and TPM status when available"/>
              <TextBlock Style="{StaticResource BodyText}" Margin="0,12,0,0" FontWeight="SemiBold"
                         Text="We never collect documents, passwords, emails, photos, or browsing history."/>
            </StackPanel>
          </Border>
          <StackPanel Orientation="Horizontal">
            <Button Content="I understand — continue" Style="{StaticResource AccentButton}" Command="{Binding ContinueFromDisclosureCommand}" Margin="0,0,10,0"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}"/>
          </StackPanel>
        </StackPanel>

        <!-- 3 Permission -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Permission}">
          <TextBlock Text="Choose scan level" Style="{StaticResource PageTitle}" Margin="0,0,0,12"/>
          <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,20"
                     Text="A basic scan works without administrator rights. Enhanced scan adds deeper storage and security diagnostics."/>
          <UniformGrid Columns="2" Margin="0,0,0,16">
            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0">
              <StackPanel>
                <TextBlock Text="Basic scan" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,16"
                           Text="Recommended for most users. No admin rights required."/>
                <Button Content="Run basic scan" Style="{StaticResource PrimaryButton}" Command="{Binding ChooseBasicScanCommand}"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}" Margin="10,0,0,0">
              <StackPanel>
                <TextBlock Text="Enhanced scan" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,16"
                           Text="SMART storage health, deeper firmware and security checks. May request admin access."/>
                <Button Content="Run enhanced scan" Style="{StaticResource AccentButton}" Command="{Binding ChooseEnhancedScanCommand}"/>
              </StackPanel>
            </Border>
          </UniformGrid>
          <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" Visibility="{Binding HasError, Converter={StaticResource BoolVis}}"/>
        </StackPanel>

        <!-- 4 Scan progress -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=ScanProgress}">
          <TextBlock Text="Scanning your device" Style="{StaticResource PageTitle}" Margin="0,0,0,8"/>
          <TextBlock Style="{StaticResource BodyText}" Text="Please keep this window open. This usually takes one to three minutes."/>
          <ProgressBar Height="10" Margin="0,22,0,10" Maximum="100" Value="{Binding ScanProgress}"
                       Foreground="{StaticResource AccentBrush}" Background="{StaticResource SurfaceMutedBrush}"/>
          <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,18"/>
          <ItemsControl ItemsSource="{Binding ScanSteps}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="3"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Style="{StaticResource StepCardBorder}" Margin="4">
                  <StackPanel>
                    <TextBlock Text="{Binding Status, Converter={StaticResource StepIcon}}" FontSize="18" FontWeight="Bold"
                               Foreground="{Binding Status, Converter={StaticResource StepBrush}}"/>
                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Margin="0,6,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Functional tests (visibility binds to shell CurrentPage — do not set DataContext on this panel) -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=FunctionalTests}">
          <StackPanel DataContext="{Binding FunctionalTests}">
          <TextBlock Text="Functional certification" Style="{StaticResource PageTitle}" Margin="0,0,0,8"/>
          <TextBlock Style="{StaticResource BodyText}" Text="{Binding StatusMessage}" Margin="0,0,0,16"/>

          <Border Style="{StaticResource CardBorder}" MinHeight="320">
            <Grid>
              <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource FuncStepVis}, ConverterParameter=Hub}">
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
              <TextBlock Style="{StaticResource BodyText}" TextWrapping="Wrap"
                         Text="Verify display, audio, camera, keyboard, touchpad, and USB. Skipped tests stay not verified — they are never reported as passed."/>
            </Border>
            <StackPanel Orientation="Horizontal">
              <Button Content="Start tests" Style="{StaticResource AccentButton}" Command="{Binding StartTestsCommand}" Margin="0,0,8,0"/>
              <Button Content="Skip all" Style="{StaticResource SecondaryButton}" Command="{Binding SkipAllCommand}" Margin="0,0,8,0"/>
              <Button Content="Continue to report" Style="{StaticResource PrimaryButton}"
                      Command="{Binding DataContext.ContinueToReportCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
          </StackPanel>

          <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource FuncStepVis}, ConverterParameter=Display}">
            <CheckBox Content="No dead pixels observed" IsChecked="{Binding DisplayDeadPixelsOk}" Margin="0,4"/>
            <CheckBox Content="Brightness OK" IsChecked="{Binding DisplayBrightnessOk}" Margin="0,4"/>
            <CheckBox Content="Colors correct" IsChecked="{Binding DisplayColorOk}" Margin="0,4"/>
            <CheckBox Content="Uniformity acceptable" IsChecked="{Binding DisplayUniformityOk}" Margin="0,4"/>
            <Button Content="Continue" Style="{StaticResource AccentButton}" Command="{Binding FinishDisplayCommand}" Margin="0,16,0,0" HorizontalAlignment="Left"/>
          </StackPanel>

          <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource FuncStepVis}, ConverterParameter=Speaker}">
            <TextBlock Text="Speaker check" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <TextBlock Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="We play a short tone in each channel. Use headphones on a laptop if speakers are hard to tell apart."/>

            <Border Style="{StaticResource AudioStepCardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource AudioStepLabel}" Text="STEP 1 OF 2"/>
                <TextBlock Style="{StaticResource AudioStepTitle}" Text="Left channel"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12"
                           Text="Play the tone, then say whether you heard it clearly on the left."/>
                <Button Content="▶  Play left tone" Command="{Binding PlaySpeakerLeftCommand}"
                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,0,0,14"/>
                <TextBlock Style="{StaticResource BodyText}" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"
                           Text="Did you hear the tone on the left?"/>
                <StackPanel Orientation="Horizontal">
                  <Button Content="Yes — left is clear" Command="{Binding AnswerLeftSpeakerYesCommand}"
                          Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                  <Button Content="No — couldn't hear left" Command="{Binding AnswerLeftSpeakerNoCommand}"
                          Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource AudioStepCardBorder}" IsEnabled="{Binding SpeakerLeftStepComplete}">
              <StackPanel>
                <TextBlock Style="{StaticResource AudioStepLabel}" Text="STEP 2 OF 2"/>
                <TextBlock Style="{StaticResource AudioStepTitle}" Text="Right channel"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12"
                           Text="Complete step 1 first, then play the right tone and confirm what you hear."/>
                <Button Content="▶  Play right tone" Command="{Binding PlaySpeakerRightCommand}"
                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,0,0,14"/>
                <TextBlock Style="{StaticResource BodyText}" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"
                           Text="Did you hear the tone on the right?"/>
                <StackPanel Orientation="Horizontal">
                  <Button Content="Yes — right is clear" Command="{Binding AnswerRightSpeakerYesCommand}"
                          Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                  <Button Content="No — couldn't hear right" Command="{Binding AnswerRightSpeakerNoCommand}"
                          Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <Button Content="Speakers not working — skip to microphone" Command="{Binding SkipSpeakersCommand}"
                    Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"/>
          </StackPanel>

          <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource FuncStepVis}, ConverterParameter=Microphone}">
            <TextBlock Text="Microphone check" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <TextBlock Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="Your voice is recorded on this device only, played back once, then deleted. Nothing is uploaded."/>

            <Border Style="{StaticResource AudioStepCardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource AudioStepLabel}" Text="STEP 1 OF 3"/>
                <TextBlock Style="{StaticResource AudioStepTitle}" Text="Record"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12"
                           Text="Speak normally for about 4 seconds after you press Record."/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                  <Button Content="●  Record sample" Command="{Binding RecordMicrophoneSampleCommand}"
                          Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"/>
                  <StackPanel VerticalAlignment="Center"
                              Visibility="{Binding IsRecordingMic, Converter={StaticResource BoolVis}}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="6" Margin="0,0,0,6"/>
                    <TextBlock Style="{StaticResource BodyText}" Text="Recording…"/>
                  </StackPanel>
                </StackPanel>
                <TextBlock Style="{StaticResource BodyText}"
                           Visibility="{Binding MicSampleReady, Converter={StaticResource BoolVis}}"
                           Foreground="{StaticResource SuccessBrush}"
                           Text="✓ Sample recorded — continue to step 2."/>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource AudioStepCardBorder}" IsEnabled="{Binding MicSampleReady}">
              <StackPanel>
                <TextBlock Style="{StaticResource AudioStepLabel}" Text="STEP 2 OF 3"/>
                <TextBlock Style="{StaticResource AudioStepTitle}" Text="Listen"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12"
                           Text="Play your recording back and listen with your speakers or headphones."/>
                <Button Content="▶  Play my recording" Command="{Binding PlayMicrophoneSampleCommand}"
                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource AudioStepCardBorder}" IsEnabled="{Binding MicSampleReady}">
              <StackPanel>
                <TextBlock Style="{StaticResource AudioStepLabel}" Text="STEP 3 OF 3"/>
                <TextBlock Style="{StaticResource AudioStepTitle}" Text="Confirm"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12"
                           Text="Did the playback sound like your voice?"/>
                <StackPanel Orientation="Horizontal">
                  <Button Content="Yes — mic works" Command="{Binding ConfirmMicrophonePassedCommand}"
                          Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                  <Button Content="No — mic doesn't work" Command="{Binding ConfirmMicrophoneFailedCommand}"
                          Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource FuncStepVis}, ConverterParameter=Camera}">
            <TextBlock Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="Live preview remains on this device. No images or video are uploaded."/>
            <Border Background="{StaticResource SurfaceMutedBrush}" CornerRadius="8" Height="220" Margin="0,0,0,8">
              <Grid>
                <Image Source="{Binding CameraPreviewFrame}" Stretch="Uniform"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsCameraStarting, Converter={StaticResource BoolVis}}">
                  <ProgressBar IsIndeterminate="True" Width="180" Height="8" Margin="0,0,0,10"/>
                  <TextBlock Text="Starting camera…" Style="{StaticResource BodyText}" HorizontalAlignment="Center"/>
                </StackPanel>
              </Grid>
            </Border>
            <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,8"
                       Text="{Binding CameraName, StringFormat=Camera: {0}}"/>
            <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,8"
                       Text="{Binding CameraResolution, StringFormat=Resolution: {0}}"/>
            <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12"
                       Text="{Binding CameraStatus}" TextWrapping="Wrap"/>
            <Border Style="{StaticResource InstructionCardBorder}" Margin="0,0,0,12"
                    Visibility="{Binding ShowsCameraAccessInstructions, Converter={StaticResource BoolVis}}">
              <StackPanel>
                <TextBlock Text="{Binding CameraHelpTitle}" FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource WarningBrush}" Margin="0,0,0,8"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,10" TextWrapping="Wrap"
                           Text="Windows must allow desktop apps to use your camera before the live preview can start."/>
                <ItemsControl ItemsSource="{Binding CameraAccessSteps}" Margin="0,0,0,12">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Style="{StaticResource BodyText}" Text="{Binding}" Margin="0,0,0,6"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="Open Windows camera settings" Command="{Binding OpenCameraSettingsCommand}"
                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
              </StackPanel>
            </Border>
            <Button Content="Retry camera" Command="{Binding RetryCameraPreviewCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8"/>
            <Button Content="I can clearly see the preview" Command="{Binding ConfirmCameraPreviewYesCommand}" Style="{StaticResource AccentButton}" Margin="0,0,0,8"/>
            <Button Content="Camera failed" Command="{Binding ConfirmCameraFailedCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"/>
          </StackPanel>

          <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource FuncStepVis}, ConverterParameter=Keyboard}">
            <TextBlock Text="{Binding KeyboardCaptureStatus}" Style="{StaticResource BodyText}" Margin="0,0,0,8"/>
            <TextBox Text="{Binding KeysPressedDisplay}" IsReadOnly="True" Height="80" TextWrapping="Wrap" Margin="0,0,0,12"/>
            <StackPanel Orientation="Horizontal">
              <Button Content="Done" Command="{Binding FinishKeyboardCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
              <Button Content="Skip" Command="{Binding SkipKeyboardCommand}" Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
          </StackPanel>

          <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource FuncStepVis}, ConverterParameter=Touchpad}">
            <CheckBox Content="Movement detected" IsChecked="{Binding TouchpadMoved}" Margin="0,4"/>
            <CheckBox Content="Left click" IsChecked="{Binding LeftClickOk}" Margin="0,4"/>
            <CheckBox Content="Right click" IsChecked="{Binding RightClickOk}" Margin="0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
              <Button Content="Continue" Command="{Binding FinishTouchpadCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
              <Button Content="Skip" Command="{Binding SkipTouchpadCommand}" Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
          </StackPanel>

          <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource FuncStepVis}, ConverterParameter=Ports}">
            <TextBlock Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,8"
                       Text="Only connection status is validated. Files and contents are never accessed."/>
            <TextBlock Style="{StaticResource BodyText}" Text="{Binding UsbStatus}" Margin="0,0,0,12"/>
            <Button Content="USB inserted" Command="{Binding ConfirmUsbInsertDetectedCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
              <Button Content="Test complete" Command="{Binding FinishUsbTestCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
              <Button Content="USB failed" Command="{Binding ConfirmUsbFailedCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
              <Button Content="Skip" Command="{Binding SkipPortsCommand}" Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
          </StackPanel>

            </Grid>
          </Border>

          <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource FuncStepVis}, ConverterParameter=Complete}"
                      Margin="0,16,0,0">
            <StackPanel Visibility="{Binding DataContext.IsPreparingReport, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolVis}}"
                        Margin="0,0,0,12">
              <ProgressBar IsIndeterminate="True" Height="8" Margin="0,0,0,10"/>
              <TextBlock Style="{StaticResource BodyText}"
                         Text="{Binding DataContext.ReportStatusMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                         TextWrapping="Wrap"/>
            </StackPanel>
            <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12" TextWrapping="Wrap"
                       Visibility="{Binding DataContext.IsReportReady, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolVis}}"
                       Text="Your inspection report is ready to review."/>
            <Button Content="View inspection report" Style="{StaticResource AccentButton}"
                    Command="{Binding DataContext.ViewInspectionReportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    IsEnabled="{Binding DataContext.IsReportReady, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="Retry report preparation" Style="{StaticResource SecondaryButton}" Margin="0,8,0,0"
                    Visibility="{Binding DataContext.ReportPreparationFailed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolVis}}"
                    Command="{Binding DataContext.RetryReportPreparationCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
          </StackPanel>
          </StackPanel>
        </StackPanel>

        <!-- 5 Result preview -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=ResultPreview}">
          <TextBlock Text="Review before submitting" Style="{StaticResource PageTitle}" Margin="0,0,0,8"/>
          <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12" TextWrapping="Wrap"
                     Text="Professional inspection summary — submit to receive your server-signed certificate."/>
          <StackPanel Visibility="{Binding IsPreparingReport, Converter={StaticResource BoolVis}}" Margin="0,0,0,12">
            <ProgressBar IsIndeterminate="True" Height="8" Margin="0,0,0,10"/>
            <TextBlock Style="{StaticResource BodyText}" Text="{Binding ReportStatusMessage}" TextWrapping="Wrap"/>
          </StackPanel>
          <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" DataContext="{Binding InspectionReportSummary}">
            <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <Border Style="{StaticResource HeroCardBorder}" Padding="18" Margin="0,0,0,18">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Recommended resale grade" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                      <TextBlock Text="{Binding RecommendedResaleGrade, TargetNullValue=—}" Style="{StaticResource ReportGradeValue}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12,8" VerticalAlignment="Center">
                      <TextBlock Text="Inspection summary" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                  </Grid>
                </Border>

                <TextBlock Style="{StaticResource ReportSectionTitle}" Text="DEVICE OVERVIEW"/>
                <TextBlock Style="{StaticResource ReportSectionBody}" Text="{Binding DeviceOverview}" Margin="0,0,0,16"/>

                <TextBlock Style="{StaticResource ReportSectionTitle}" Text="HEALTH SUMMARY"/>
                <TextBlock Style="{StaticResource ReportSectionBody}" Text="{Binding HealthSummary}" Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource ReportSectionTitle}" Text="BATTERY"/>
                    <TextBlock Style="{StaticResource ReportSectionBody}" Text="{Binding BatteryCondition}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Style="{StaticResource ReportSectionTitle}" Text="STORAGE"/>
                    <TextBlock Style="{StaticResource ReportSectionBody}" Text="{Binding StorageCondition}" TextWrapping="Wrap"/>
                  </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource ReportSectionTitle}" Text="PERFORMANCE"/>
                    <TextBlock Style="{StaticResource ReportSectionBody}" Text="{Binding PerformanceRating}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Style="{StaticResource ReportSectionTitle}" Text="SECURITY"/>
                    <TextBlock Style="{StaticResource ReportSectionBody}" Text="{Binding SecurityRating}"/>
                  </StackPanel>
                </Grid>

                <TextBlock Style="{StaticResource ReportSectionTitle}" Text="FUNCTIONAL TESTS"/>
                <ItemsControl ItemsSource="{Binding FunctionalTestLines}" Margin="0,0,0,16">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="•" Style="{StaticResource ReportSectionBody}" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding}" Style="{StaticResource ReportSectionBody}"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Style="{StaticResource ReportSectionTitle}" Text="REFURBISHER NOTES"/>
                <TextBlock Style="{StaticResource ReportSectionBody}"
                           Text="{Binding RefurbisherNotes, TargetNullValue=No additional notes.}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
              </StackPanel>
            </ScrollViewer>
          </Border>
          <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" DataContext="{Binding Summary}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Device" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding DeviceName, StringFormat=Name: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding OsVersion, StringFormat=OS: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding Cpu, StringFormat=CPU: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding Ram, StringFormat=RAM: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding Storage, StringFormat=Storage: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding Display, StringFormat=Display: {0}}"/>
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="Health &amp; checks" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding Battery, StringFormat=Battery: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding StorageHealth, StringFormat=Storage health: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding Graphics, StringFormat=Graphics: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding Security, StringFormat=Security: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding CoreChecks, StringFormat=Checks: {0}}"/>
                <TextBlock Style="{StaticResource BodyText}" Text="{Binding ScanType, StringFormat=Scan: {0}}"/>
                <TextBlock Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0"
                           Text="{Binding CompletenessPercent, StringFormat=Completeness: {0:F0}%}"/>
              </StackPanel>
            </Grid>
          </Border>
          <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20" DataContext="{Binding Summary}"
                  Visibility="{Binding HasWarnings, Converter={StaticResource BoolVis}}">
            <StackPanel>
              <TextBlock Text="Collection notes" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
              <ItemsControl ItemsSource="{Binding Warnings}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Style="{StaticResource BodyText}" Text="{Binding StringFormat=• {0}}" Margin="0,0,0,4"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
          <StackPanel Orientation="Horizontal">
            <Button Content="Submit to VerifyTech" Style="{StaticResource AccentButton}" Command="{Binding SubmitCertificationCommand}" Margin="0,0,10,0"/>
            <Button Content="Scan again" Style="{StaticResource SecondaryButton}" Command="{Binding BackToWelcomeCommand}"/>
          </StackPanel>
          <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" Margin="0,12,0,0"
                     Visibility="{Binding HasError, Converter={StaticResource BoolVis}}"/>
        </StackPanel>

        <!-- 6 Submitting -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Submitting}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="Creating your certificate" Style="{StaticResource PageTitle}" HorizontalAlignment="Center"/>
          <TextBlock Style="{StaticResource BodyText}" Margin="0,16,0,0" HorizontalAlignment="Center" Text="{Binding SubmissionStatus}"/>
        </StackPanel>

        <!-- 7 Certificate success -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=CertificateSuccess}">
          <Border Background="#E6F4F1" CornerRadius="14" Padding="28" Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock Text="Certified" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding CertResult.CertificateCode}" FontSize="22" FontFamily="Consolas" Margin="0,14,0,0" HorizontalAlignment="Center"/>
              <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,0" HorizontalAlignment="Center"
                         Text="Your certificate was signed by VerifyTech."/>
            </StackPanel>
          </Border>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Copy code" Style="{StaticResource SecondaryButton}" Command="{Binding CopyCertificateCodeCommand}" Margin="4"/>
            <Button Content="Copy report link" Style="{StaticResource SecondaryButton}" Command="{Binding CopyReportLinkCommand}" Margin="4"/>
            <Button Content="Open report" Style="{StaticResource PrimaryButton}" Command="{Binding OpenReportCommand}" Margin="4"/>
          </StackPanel>
          <Button Content="Done" Style="{StaticResource AccentButton}" Command="{Binding FinishCertificateCommand}" Margin="0,24,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 8 Uninstall prompt -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=UninstallPrompt}">
          <TextBlock Text="All set" Style="{StaticResource PageTitle}" Margin="0,0,0,12"/>
          <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
            <StackPanel>
              <TextBlock Style="{StaticResource BodyText}"
                         Text="You can keep VerifyTech Agent installed for future certifications, or remove it now."/>
              <TextBlock Style="{StaticResource BodyText}" Margin="0,12,0,0"
                         Text="To uninstall later: Windows Settings → Apps → VerifyTech Agent."/>
            </StackPanel>
          </Border>
          <StackPanel Orientation="Horizontal">
            <Button Content="Remove local scan cache" Style="{StaticResource SecondaryButton}" Command="{Binding ClearLocalCacheCommand}" Margin="0,0,10,0"/>
            <Button Content="Keep installed &amp; exit" Style="{StaticResource AccentButton}" Command="{Binding KeepInstalledCommand}" Margin="0,0,10,0"/>
            <Button Content="Exit" Style="{StaticResource SecondaryButton}" Command="{Binding ExitAppCommand}"/>
          </StackPanel>
        </StackPanel>

      </Grid>
    </ScrollViewer>

    <TextBlock Grid.Row="2" Text="VerifyTech · Hardware diagnostics only · TLS encrypted"
               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,18,0,0"/>
  </Grid>
</Window>
