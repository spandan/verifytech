<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="BackgroundColor">#F8FAFC</Color>
  <Color x:Key="SurfaceColor">#FFFFFF</Color>
  <Color x:Key="SurfaceMutedColor">#F1F5F9</Color>
  <Color x:Key="BorderColor">#E2E8F0</Color>
  <Color x:Key="TextPrimaryColor">#0F172A</Color>
  <Color x:Key="TextSecondaryColor">#64748B</Color>
  <Color x:Key="AccentColor">#0B6E63</Color>
  <Color x:Key="PrimaryButtonColor">#0F766E</Color>
  <Color x:Key="SuccessColor">#16A34A</Color>
  <Color x:Key="WarningColor">#D97706</Color>
  <Color x:Key="ErrorColor">#DC2626</Color>

  <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
  <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMutedColor}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="PrimaryButtonBrush" Color="{StaticResource PrimaryButtonColor}"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
  <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
  <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

  <Style x:Key="PageTitle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="22"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
  </Style>

  <Style x:Key="SectionTitle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="15"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
  </Style>

  <Style x:Key="BodyText" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="LineHeight" Value="20"/>
  </Style>

  <Style x:Key="CompactCheckBox" TargetType="CheckBox">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="Margin" Value="0,6"/>
    <Setter Property="IsThreeState" Value="False"/>
  </Style>

  <Style x:Key="StepCardBorder" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="12"/>
    <Setter Property="MinHeight" Value="72"/>
  </Style>

  <Style x:Key="CardBorder" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="14"/>
  </Style>

  <Style x:Key="HeroCardBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
    <Setter Property="Background" Value="#F0FDFA"/>
    <Setter Property="BorderBrush" Value="#CCFBF1"/>
  </Style>

  <Style x:Key="PrimaryButton" TargetType="Button">
    <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Background" Value="#CBD5E1"/>
              <Setter Property="Foreground" Value="#94A3B8"/>
              <Setter Property="Cursor" Value="Arrow"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
  </Style>

  <Style x:Key="SecondaryButton" TargetType="Button">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
              <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
              <Setter Property="Cursor" Value="Arrow"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ChoiceButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="MinWidth" Value="120"/>
  </Style>

  <Style x:Key="ReportSectionTitle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
    <Setter Property="Margin" Value="0,0,0,6"/>
  </Style>

  <Style x:Key="ReportSectionBody" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="LineHeight" Value="20"/>
  </Style>

  <Style x:Key="ReportGradeValue" TargetType="TextBlock">
    <Setter Property="FontSize" Value="32"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
  </Style>

  <Style x:Key="InstructionCardBorder" TargetType="Border">
    <Setter Property="Background" Value="#FFF7ED"/>
    <Setter Property="BorderBrush" Value="#FDBA74"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="12"/>
  </Style>

  <Style x:Key="AudioStepCardBorder" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="12"/>
    <Setter Property="Margin" Value="0,0,0,10"/>
  </Style>

  <Style x:Key="AudioStepLabel" TargetType="TextBlock">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="Margin" Value="0,0,0,2"/>
  </Style>

  <Style x:Key="AudioStepTitle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="Margin" Value="0,0,0,4"/>
  </Style>

  <Style x:Key="FuncTestToolbar" TargetType="Border">
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="Padding" Value="0,0,0,14"/>
    <Setter Property="Margin" Value="0,0,0,16"/>
  </Style>

  <Style x:Key="FuncStepIntro" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="Margin" Value="0,0,0,16"/>
  </Style>

  <Style x:Key="FuncStepProgressLabel" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
  </Style>

  <Style x:Key="FuncStepProgressLabelActive" TargetType="TextBlock" BasedOn="{StaticResource FuncStepProgressLabel}">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
  </Style>

  <Style x:Key="FuncSubStepPanel" TargetType="Border">
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="16"/>
    <Setter Property="Margin" Value="0,0,0,10"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="Opacity" Value="0.55"/>
  </Style>

  <Style x:Key="FuncSubStepPanelActive" TargetType="Border" BasedOn="{StaticResource FuncSubStepPanel}">
    <Setter Property="Background" Value="#F0FDFA"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="Opacity" Value="1"/>
  </Style>

  <Style x:Key="FuncSubStepPanelDone" TargetType="Border" BasedOn="{StaticResource FuncSubStepPanel}">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
    <Setter Property="Opacity" Value="0.85"/>
  </Style>

  <Style x:Key="FuncPlayButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
    <Setter Property="Padding" Value="20,10"/>
    <Setter Property="MinWidth" Value="160"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
  </Style>

  <Style x:Key="CameraPreviewFrame" TargetType="Border">
    <Setter Property="Background" Value="#0F172A"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="BorderThickness" Value="3"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="ClipToBounds" Value="True"/>
  </Style>

  <Style x:Key="CameraPreviewFrameLive" TargetType="Border" BasedOn="{StaticResource CameraPreviewFrame}">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
  </Style>

  <Style x:Key="LiveBadge" TargetType="Border">
    <Setter Property="Background" Value="#DC2626"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="8,3"/>
    <Setter Property="HorizontalAlignment" Value="Left"/>
    <Setter Property="VerticalAlignment" Value="Top"/>
    <Setter Property="Margin" Value="12"/>
  </Style>

  <Style x:Key="ReportCheckLabel" TargetType="TextBlock">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="LineHeight" Value="14"/>
  </Style>

  <Style x:Key="ReportCheckDetail" TargetType="TextBlock">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="Margin" Value="0,2,0,0"/>
    <Setter Property="LineHeight" Value="16"/>
  </Style>

  <Style x:Key="ReportCheckHeadline" TargetType="TextBlock">
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="LineHeight" Value="18"/>
  </Style>

  <Style x:Key="TextBoxStyle" TargetType="TextBox">
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
  </Style>

  <Geometry x:Key="CopyIconGeometry">M4,2 L11,2 C11.5522847,2 12,2.44771525 12,3 L12,4 L13,4 C13.5522847,4 14,4.44771525 14,5 L14,13 C14,13.5522847 13.5522847,14 13,14 L6,14 C5.44771525,14 5,13.5522847 5,13 L5,12 L4,12 C3.44771525,12 3,11.5522847 3,11 L3,3 C3,2.44771525 3.44771525,2 4,2 Z M6,5 L6,12 L13,12 L13,5 L6,5 Z M4,4 L4,11 L5,11 L5,4 L11,4 L11,3 L4,3 L4,4 Z</Geometry>

  <Style x:Key="CopyIconPath" TargetType="Path">
    <Setter Property="Data" Value="{StaticResource CopyIconGeometry}"/>
    <Setter Property="Fill" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="Stretch" Value="Uniform"/>
    <Setter Property="Width" Value="16"/>
    <Setter Property="Height" Value="16"/>
  </Style>

  <Style x:Key="IconButton" TargetType="Button">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="6"/>
    <Setter Property="MinWidth" Value="32"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="ToolTip" Value="Copy"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
              <Setter Property="Cursor" Value="Arrow"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
