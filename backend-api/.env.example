# Backend API
DEBUG=true
PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
CERTIFICATE_TTL_DAYS=365

# Supabase (required)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Direct Postgres URI — for scripts/reset-database.sh only (not used by the API)
# Supabase → Project Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase Storage — agent executables (private bucket, signed URLs from API)
SUPABASE_AGENT_BUCKET=agent-releases
SUPABASE_AGENT_FILENAME=DeviceCertAgent.exe
SUPABASE_AGENT_SIGNED_URL_TTL_SECONDS=3600

# Scan sessions (Windows agent)
SCAN_SESSION_TTL_MINUTES=20
ALLOWED_AGENT_VERSIONS=0.1.0,0.2.0,1.0.0,2.0.0,2.1.0,2.3.0
SUPABASE_EVIDENCE_BUCKET=certification-evidence
